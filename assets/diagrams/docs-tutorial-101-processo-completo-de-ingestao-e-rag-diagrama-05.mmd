        W3["Executa ContentIngestionOrchestrator"]
    end

    subgraph QA
        Q1["QuestionService"]
        Q2["QAQuestionProcessor"]
        Q3["IntelligentRAGOrchestrator"]
        Q4["GenerationEngine"]
    end

    subgraph Infra
        I1["RabbitMQ"]
        I2["Redis"]
        I3["PostgreSQL"]
        I4["BM25"]
        I5["Qdrant ou Azure Search"]
    end

    C1 --> A1 --> A2 --> A3
    A3 --> I1 --> W1 --> W2 --> W3 --> I3
